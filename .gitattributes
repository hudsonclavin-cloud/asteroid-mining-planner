# Prevent GitHub Linguist from counting generated/vendored files
# against the repo's language breakdown (was ~90% HTML).

# The main app shell is generated by the build process going forward
index.html linguist-generated

# Built output
dist/** linguist-generated

# Texture assets — binary, not code
textures/** linguist-vendored

# Cloudflare Worker proxy — vendored infrastructure
worker/** linguist-vendored
proxy/** linguist-vendored
